{
  "name": "asyncbase/asyncbase",
  "description": "AsyncBase PHP SDK — queue primitive client + Laravel queue driver",
  "type": "library",
  "license": "MIT",
  "keywords": ["queue", "async", "message-queue", "asyncbase", "sqs", "laravel"],
  "homepage": "https://asyncbase.dev",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.9",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64",
    "illuminate/container": "^10.0 || ^11.0 || ^12.0",
    "illuminate/contracts": "^10.0 || ^11.0 || ^12.0",
    "illuminate/queue": "^10.0 || ^11.0 || ^12.0",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12.3"
  },
  "suggest": {
    "illuminate/queue": "Required to use the asyncbase queue driver (queue:work asyncbase)."
  },
  "autoload": {
    "psr-4": {
      "AsyncBase\\": "src/"
    },
    "files": [
      "src/Queue.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "AsyncBase\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AsyncBase\\Laravel\\AsyncBaseServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyze": "phpstan analyse",
    "format": "php-cs-fixer fix"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
